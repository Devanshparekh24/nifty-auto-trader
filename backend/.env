# Angel Broking API Credentials
ANGEL_API_KEY=mock_api_key_for_testing
ANGEL_CLIENT_ID=mock_client_id_for_testing
ANGEL_PASSWORD=mock_password_for_testing

# Strategy Configuration
NIFTY_STRIKE_INTERVAL=100
OPTIONS_EXPIRY=WEEKLY

# Risk Management - CRITICAL SETTINGS
MAX_LOSS_PER_TRADE=2000
MAX_POSITIONS=3
MAX_DAILY_LOSS=10000
MAX_DAILY_PROFIT=50000
PROFIT_TARGET_PERCENT=20

# Paper Trading (Set to false for LIVE TRADING)
PAPER_TRADING=true

# Server Configuration
PORT=3000

# Notifications (Optional)
TELEGRAM_ENABLED=false
TELEGRAM_CHAT_ID=your_chat_id
TELEGRAM_BOT_TOKEN=your_bot_token

EMAIL_ENABLED=false
EMAIL_FROM=your_email@gmail.com
EMAIL_TO=recipient@gmail.com
