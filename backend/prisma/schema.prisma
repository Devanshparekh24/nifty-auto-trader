datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Trade {
  id              Int      @id @default(autoincrement())
  tradeId         String   @unique @map("trade_id")
  entryTime       DateTime @map("entry_time")
  exitTime        DateTime? @map("exit_time")
  symbol          String
  strikeSelection String   @map("strike_selection")
  entryPrice      Float    @map("entry_price")
  exitPrice       Float?   @map("exit_price")
  maxLoss         Float    @map("max_loss")
  maxProfit       Float    @map("max_profit")
  realizedPL      Float?   @map("realized_pl")
  status          String
  exitReason      String?  @map("exit_reason")
  duration        Int?
  createdAt       DateTime @default(now()) @map("created_at")
  orders          Order[]

  @@map("trades")
}

model Order {
  id        Int      @id @default(autoincrement())
  orderId   String   @map("order_id")
  tradeId   String   @map("trade_id")
  side      String
  symbol    String
  quantity  Int
  price     Float
  status    String
  timestamp DateTime
  trade     Trade    @relation(fields: [tradeId], references: [tradeId], onDelete: Cascade)

  @@map("orders")
}

model DailySummary {
  id             Int      @id @default(autoincrement())
  date           String   @unique
  totalTrades    Int      @map("total_trades")
  winningTrades  Int      @map("winning_trades")
  losingTrades   Int      @map("losing_trades")
  totalProfit    Float    @map("total_profit")
  totalLoss      Float    @map("total_loss")
  netPL          Float    @map("net_pl")
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("daily_summaries")
}
